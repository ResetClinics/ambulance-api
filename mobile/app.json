      },
      "package": "com.alergy.ambulance"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "backgroundColor": "#FFFFFF"
    },
    "extra": {
      "eas": {
        "projectId": "8d5f9df8-d5d6-4a34-82f6-507bfbb270a4"
      }
